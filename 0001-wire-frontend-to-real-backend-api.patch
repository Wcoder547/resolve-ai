+// Maps the backend's ChatSource + RetrievedChunk shapes onto the display Source
+// shape this page already renders. retrievedChunks carries the actual chunk text;
+// sources carries the citation metadata. Conversation history only returns
+// sources (no chunk text), so preview falls back gracefully when absent.
+function toDisplaySources(sources: ChatSource[] = [], retrievedChunks: RetrievedChunk[] = []): Source[] {
+  return sources.map(s => {
+    const chunk = retrievedChunks.find(c => c.id === s.chunkId);
+    return {
+      name: s.sourceName,
+      doc: s.documentTitle,
+      chunk: `Chunk ${s.chunkIndex}`,
+      score: Math.round(s.score * 100) / 100,
+      preview: chunk?.chunkText || "Preview unavailable for this message.",
+    };
+  });
+}
 

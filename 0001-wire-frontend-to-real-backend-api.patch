+# Copy this file to .env and fill in the values below.
+# Everything not listed here has a working default in src/config/env.ts.
+
+NODE_ENV=development
+PORT=5000
+
+# --- Required, no default ---
+
+# Matches docker-compose.yml's postgres service.
+DATABASE_URL=postgresql://resolveai:resolveai_password@localhost:5432/resolveai_db
+
+# Generate with: openssl rand -hex 32
+JWT_ACCESS_SECRET=replace-with-a-random-string-at-least-20-characters
+JWT_REFRESH_SECRET=replace-with-a-different-random-string-at-least-20-characters
+
+# The Python AI service (services/ai-service), which listens on 8000 by default.
+AI_SERVICE_URL=http://localhost:8000
+
+# --- Commonly overridden ---
+
+# Must match the frontend's origin (apps/web/.env.local's NEXT_PUBLIC_API_URL host).
+CORS_ORIGIN=http://localhost:3000
+
+# Matches docker-compose.yml's redis service.
+REDIS_URL=redis://localhost:6379
+
+STORAGE_PROVIDER=local
+LOG_LEVEL=info

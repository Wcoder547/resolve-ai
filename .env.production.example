# Runtime
NODE_ENV=production
ENVIRONMENT=production

# Public ports
API_PORT=5000
AI_SERVICE_PORT=8000

# PostgreSQL
POSTGRES_DB=resolveai_db
POSTGRES_USER=resolveai
POSTGRES_PASSWORD=change_this_postgres_password

DATABASE_URL=postgresql://resolveai:change_this_postgres_password@postgres:5432/resolveai_db?schema=public

# Redis
REDIS_URL=redis://redis:6379
QUEUE_PREFIX=resolveai

# Node API
PORT=5000
CORS_ORIGIN=https://your-frontend-domain.com
REQUEST_BODY_LIMIT=10mb
MAX_UPLOAD_FILE_SIZE_MB=10

JWT_ACCESS_SECRET=change_this_access_secret_minimum_32_chars
JWT_REFRESH_SECRET=change_this_refresh_secret_minimum_32_chars

AI_SERVICE_URL=http://ai-service:8000

AI_CHAT_TIMEOUT_MS=70000
RAG_MAX_CONTEXT_CHARS=12000
RAG_MIN_RELEVANCE_SCORE=0.0001

SLOW_QUERY_LOG_MS=300
LOG_LEVEL=info

ENABLE_METRICS=true
METRICS_TOKEN=change_this_metrics_token
HEALTH_CHECK_TIMEOUT_MS=5000

# Queue
KNOWLEDGE_INGESTION_CONCURRENCY=2
INGESTION_JOB_ATTEMPTS=3
INGESTION_JOB_BACKOFF_MS=10000

# Storage
STORAGE_PROVIDER=local

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=resolveai-knowledge
R2_PRESIGNED_URL_EXPIRES_SECONDS=600

# AI Service
SERVICE_NAME=ResolveAI AI Service
API_VERSION=1.0.0

LLM_PROVIDER=openrouter

OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=openrouter/free

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

REQUEST_TIMEOUT_SECONDS=60


# Backups
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7
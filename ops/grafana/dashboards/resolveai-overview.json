{
  "title": "ResolveAI Overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "type": "stat",
      "title": "API Up",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "up{job=\"resolveai-api\"}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "AI Service Up",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "up{job=\"resolveai-ai-service\"}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Failed Agent Runs",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "resolveai_api_agent_runs_failed_total"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Pending Tool Approvals",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "resolveai_api_agent_tool_calls_pending_total"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "API Request Rate",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(resolveai_api_http_requests_total[5m]))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "API 5xx Rate",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(resolveai_api_http_requests_total{status_code=~\"5..\"}[5m]))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "AI Service Request Rate",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(resolveai_ai_http_requests_total[5m]))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Daily AI Token Usage",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "resolveai_api_ai_usage_daily_tokens_total"
        }
      ]
    }
  ]
}
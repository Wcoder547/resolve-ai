NODE_ENV=test
PORT=5001

DATABASE_URL="postgresql://resolveai:resolveai_password@localhost:5432/resolveai_test?schema=public"

JWT_ACCESS_SECRET="test_access_secret_123456789_minimum_32_chars"
JWT_REFRESH_SECRET="test_refresh_secret_123456789_minimum_32_chars"

AI_SERVICE_URL="http://localhost:8000"

CORS_ORIGIN="http://localhost:3000"
REQUEST_BODY_LIMIT="10mb"
MAX_UPLOAD_FILE_SIZE_MB=10

REDIS_URL="redis://localhost:6379"
QUEUE_PREFIX="resolveai-test"

AI_CHAT_TIMEOUT_MS=70000
AI_EMBEDDING_TIMEOUT_MS=120000
QUESTION_REWRITE_TIMEOUT_MS=30000

FOLLOWUP_REWRITE_ENABLED=true
CHAT_HISTORY_LIMIT=12
CHAT_HISTORY_MAX_CHARS=6000

RAG_MAX_CONTEXT_CHARS=12000
RAG_MIN_RELEVANCE_SCORE=0.0001
RAG_MIN_HYBRID_SCORE=0.05

HYBRID_SEARCH_ENABLED=true
RAG_KEYWORD_TOP_K=20
RAG_VECTOR_TOP_K=20
RAG_RERANK_TOP_K=8

RAG_KEYWORD_WEIGHT=0.40
RAG_VECTOR_WEIGHT=0.50
RAG_TERM_COVERAGE_WEIGHT=0.10

EMBEDDING_DIMENSIONS=384

SLOW_QUERY_LOG_MS=300
LOG_LEVEL="silent"

ENABLE_METRICS=false
METRICS_TOKEN=""
HEALTH_CHECK_TIMEOUT_MS=5000

STORAGE_PROVIDER="local"

R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="resolveai-knowledge"
R2_PRESIGNED_URL_EXPIRES_SECONDS=600

KNOWLEDGE_INGESTION_CONCURRENCY=1
INGESTION_JOB_ATTEMPTS=1
INGESTION_JOB_BACKOFF_MS=1000

AI_USAGE_TRACKING_ENABLED=true
AI_DAILY_REQUEST_LIMIT=1000
AI_DAILY_TOKEN_LIMIT=200000
AI_MONTHLY_TOKEN_LIMIT=3000000
AI_INPUT_COST_PER_1M_TOKENS=0
AI_OUTPUT_COST_PER_1M_TOKENS=0

RAG_EVAL_USER_EMAIL="waseem@example.com"
RAG_EVAL_PASSING_SCORE=0.75
RAG_EVAL_OUTPUT_DIR="eval-reports-test"
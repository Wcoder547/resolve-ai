generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  ADMIN
  SUPPORT_AGENT
  DEVELOPER
  VIEWER
}

enum KnowledgeSourceType {
  FILE
  URL
  GITHUB
  MARKDOWN
  TEXT
}

enum KnowledgeSourceStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model User {
  id           String @id @default(uuid())
  name         String
  email        String @unique
  passwordHash String

  memberships             OrganizationMember[]
  refreshTokens           RefreshToken[]
  auditLogs               AuditLog[]
  createdKnowledgeSources KnowledgeSource[]    @relation("KnowledgeSourceCreatedBy")

  conversations Conversation[]
  messages      Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Organization {
  id   String @id @default(uuid())
  name String
  slug String @unique
  plan String @default("FREE")

  members          OrganizationMember[]
  auditLogs        AuditLog[]
  knowledgeSources KnowledgeSource[]
  documents        Document[]
  documentChunks   DocumentChunk[]

  conversations Conversation[]
  messages      Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrganizationMember {
  id             String   @id @default(uuid())
  userId         String
  organizationId String
  role           UserRole @default(VIEWER)

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, organizationId])
  @@index([userId, createdAt])
  @@index([organizationId, role])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  revokedAt DateTime?
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@index([userId, revokedAt, expiresAt])
}

model AuditLog {
  id             String  @id @default(uuid())
  userId         String?
  organizationId String?
  action         String
  metadata       Json?

  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model KnowledgeSource {
  id              String                @id @default(uuid())
  organizationId  String
  createdByUserId String?
  type            KnowledgeSourceType
  name            String
  status          KnowledgeSourceStatus @default(PENDING)
  url             String?
  filePath        String?
  storageProvider String                @default("LOCAL")
  storageKey      String?
  storageBucket   String?
  storageRegion   String?
  mimeType        String?
  sizeBytes       Int?
  metadata        Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("KnowledgeSourceCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  documents    Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([createdByUserId])
  @@index([organizationId, status])
  @@index([organizationId, type])
  @@index([organizationId, createdAt])
}

model Document {
  id             String  @id @default(uuid())
  organizationId String
  sourceId       String
  title          String
  contentHash    String?
  metadata       Json?

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  source       KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  chunks       DocumentChunk[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([sourceId])
  @@index([organizationId, contentHash])
  @@index([organizationId, createdAt])
}

model DocumentChunk {
  id                  String                      @id @default(uuid())
  organizationId      String
  documentId          String
  chunkIndex          Int
  chunkText           String
  tokenCount          Int?
  embeddingId         String?
  embedding           Unsupported("vector(384)")?
  embeddingProvider   String?
  embeddingModel      String?
  embeddingDimensions Int?
  embeddedAt          DateTime?
  metadata            Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  document     Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([documentId, chunkIndex])
  @@index([organizationId])
  @@index([documentId])
  @@index([organizationId, documentId])
  @@index([organizationId, createdAt])
  @@index([embeddedAt])
}

model Conversation {
  id             String  @id @default(uuid())
  organizationId String
  userId         String?
  title          String
  metadata       Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages     Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([userId])
  @@index([organizationId, updatedAt])
  @@index([organizationId, userId, updatedAt])
}

model Message {
  id             String      @id @default(uuid())
  organizationId String
  conversationId String
  userId         String?
  role           MessageRole
  content        String
  sources        Json?
  metadata       Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([conversationId])
  @@index([userId])
  @@index([conversationId, createdAt])
  @@index([organizationId, createdAt])
}

model AiUsageEvent {
  id             String  @id @default(uuid())
  organizationId String
  userId         String?
  conversationId String?
  messageId      String?

  operation String
  provider  String
  model     String

  promptTokens     Int @default(0)
  completionTokens Int @default(0)
  totalTokens      Int @default(0)

  estimatedCostUsd Float   @default(0)
  isEstimated      Boolean @default(true)

  metadata Json?

  createdAt DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([organizationId, operation, createdAt])
  @@index([userId, createdAt])
  @@index([conversationId])
  @@index([messageId])
}

model OrganizationAiUsageDaily {
  id             String   @id @default(uuid())
  organizationId String
  date           DateTime

  requestCount Int @default(0)

  promptTokens     Int @default(0)
  completionTokens Int @default(0)
  totalTokens      Int @default(0)

  estimatedCostUsd Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, date])
  @@index([organizationId, date])
}

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  ADMIN
  SUPPORT_AGENT
  DEVELOPER
  VIEWER
}

enum KnowledgeSourceType {
  FILE
  URL
  GITHUB
  MARKDOWN
  TEXT
}

enum KnowledgeSourceStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum AgentRunStatus {
  RUNNING
  COMPLETED
  COMPLETED_WITH_GUARDRAIL_WARNING
  FAILED
}

enum AgentToolApprovalStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
  EXECUTED
  FAILED
}

enum IntegrationProvider {
  SLACK_WEBHOOK
  TICKETING_WEBHOOK
  GENERIC_WEBHOOK
}

enum IntegrationStatus {
  ACTIVE
  DISABLED
}

model User {
  id           String @id @default(uuid())
  name         String
  email        String @unique
  passwordHash String

  memberships             OrganizationMember[]
  refreshTokens           RefreshToken[]
  auditLogs               AuditLog[]
  createdKnowledgeSources KnowledgeSource[]    @relation("KnowledgeSourceCreatedBy")
  agentRuns               AgentRun[]

  conversations Conversation[]
  messages      Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Organization {
  id   String @id @default(uuid())
  name String
  slug String @unique
  plan String @default("FREE")

  members          OrganizationMember[]
  auditLogs        AuditLog[]
  knowledgeSources KnowledgeSource[]
  documents        Document[]
  documentChunks   DocumentChunk[]
  agentRuns        AgentRun[]

  conversations Conversation[]
  messages      Message[]

  integrations             OrganizationIntegration[]
  integrationExecutionLogs IntegrationExecutionLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrganizationMember {
  id             String   @id @default(uuid())
  userId         String
  organizationId String
  role           UserRole @default(VIEWER)

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, organizationId])
  @@index([userId, createdAt])
  @@index([organizationId, role])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  revokedAt DateTime?
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@index([userId, revokedAt, expiresAt])
}

model AuditLog {
  id             String  @id @default(uuid())
  userId         String?
  organizationId String?
  action         String
  metadata       Json?

  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model KnowledgeSource {
  id              String                @id @default(uuid())
  organizationId  String
  createdByUserId String?
  type            KnowledgeSourceType
  name            String
  status          KnowledgeSourceStatus @default(PENDING)
  url             String?
  filePath        String?
  storageProvider String                @default("LOCAL")
  storageKey      String?
  storageBucket   String?
  storageRegion   String?
  mimeType        String?
  sizeBytes       Int?
  metadata        Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("KnowledgeSourceCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  documents    Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([createdByUserId])
  @@index([organizationId, status])
  @@index([organizationId, type])
  @@index([organizationId, createdAt])
}

model Document {
  id             String  @id @default(uuid())
  organizationId String
  sourceId       String
  title          String
  contentHash    String?
  metadata       Json?

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  source       KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  chunks       DocumentChunk[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([sourceId])
  @@index([organizationId, contentHash])
  @@index([organizationId, createdAt])
}

model DocumentChunk {
  id                  String                      @id @default(uuid())
  organizationId      String
  documentId          String
  chunkIndex          Int
  chunkText           String
  tokenCount          Int?
  embeddingId         String?
  embedding           Unsupported("vector(384)")?
  embeddingProvider   String?
  embeddingModel      String?
  embeddingDimensions Int?
  embeddedAt          DateTime?
  metadata            Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  document     Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([documentId, chunkIndex])
  @@index([organizationId])
  @@index([documentId])
  @@index([organizationId, documentId])
  @@index([organizationId, createdAt])
  @@index([embeddedAt])
}

model Conversation {
  id             String  @id @default(uuid())
  organizationId String
  userId         String?
  title          String
  metadata       Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages     Message[]
  agentRuns    AgentRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([userId])
  @@index([organizationId, updatedAt])
  @@index([organizationId, userId, updatedAt])
}

model Message {
  id             String      @id @default(uuid())
  organizationId String
  conversationId String
  userId         String?
  role           MessageRole
  content        String
  sources        Json?
  metadata       Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  agentRuns    AgentRun[]

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([conversationId])
  @@index([userId])
  @@index([conversationId, createdAt])
  @@index([organizationId, createdAt])
}

model AiUsageEvent {
  id             String  @id @default(uuid())
  organizationId String
  userId         String?
  conversationId String?
  messageId      String?

  operation String
  provider  String
  model     String

  promptTokens     Int @default(0)
  completionTokens Int @default(0)
  totalTokens      Int @default(0)

  estimatedCostUsd Float   @default(0)
  isEstimated      Boolean @default(true)

  metadata Json?

  createdAt DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([organizationId, operation, createdAt])
  @@index([userId, createdAt])
  @@index([conversationId])
  @@index([messageId])
}

model OrganizationAiUsageDaily {
  id             String   @id @default(uuid())
  organizationId String
  date           DateTime

  requestCount Int @default(0)

  promptTokens     Int @default(0)
  completionTokens Int @default(0)
  totalTokens      Int @default(0)

  estimatedCostUsd Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, date])
  @@index([organizationId, date])
}

model AgentRun {
  id             String  @id @default(uuid())
  externalRunId  String?
  organizationId String
  userId         String?
  conversationId String?
  messageId      String?

  status AgentRunStatus @default(RUNNING)

  question           String
  standaloneQuestion String?
  answer             String?

  agentsUsed      Json?
  citations       Json?
  triage          Json?
  retrievalReview Json?
  diagnostic      Json?
  resolution      Json?
  qa              Json?
  metadata        Json?

  grounded         Boolean @default(false)
  confidence       String?
  needsEscalation  Boolean @default(false)
  escalationReason String?

  provider       String?
  model          String?
  promptVersion  String?
  fallbackUsed   Boolean @default(false)
  providerErrors Json?

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  message      Message?      @relation(fields: [messageId], references: [id], onDelete: SetNull)

  steps     AgentStep[]
  toolCalls AgentToolCall[]

  startedAt   DateTime  @default(now())
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([conversationId, createdAt])
  @@index([messageId])
  @@index([status])
}

model AgentStep {
  id         String @id @default(uuid())
  agentRunId String

  agentName String
  status    String

  provider  String?
  model     String?
  latencyMs Int?

  input  Json?
  output Json?
  error  String?

  agentRun AgentRun @relation(fields: [agentRunId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([agentRunId])
  @@index([agentName])
  @@index([status])
}

model AgentToolCall {
  id         String @id @default(uuid())
  agentRunId String

  toolCallId       String?
  toolName         String
  toolCategory     String?
  requiresApproval Boolean @default(false)

  status         String
  approvalStatus AgentToolApprovalStatus @default(NOT_REQUIRED)
  reason         String?

  latencyMs Int?

  input  Json?
  output Json?
  error  String?

  approvedByUserId String?
  rejectedByUserId String?

  approvedAt DateTime?
  rejectedAt DateTime?
  executedAt DateTime?

  agentRun AgentRun @relation(fields: [agentRunId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentRunId])
  @@index([toolName])
  @@index([status])
  @@index([approvalStatus])
  @@index([requiresApproval])
}

model OrganizationIntegration {
  id             String              @id @default(uuid())
  organizationId String
  provider       IntegrationProvider
  name           String
  status         IntegrationStatus   @default(ACTIVE)

  config               Json?
  encryptedCredentials String

  createdByUserId String?
  updatedByUserId String?

  lastUsedAt DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, provider])
  @@index([organizationId, status])
}

model IntegrationExecutionLog {
  id             String  @id @default(uuid())
  organizationId String
  integrationId  String?

  provider IntegrationProvider
  toolName String
  status   String

  request  Json?
  response Json?
  error    String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([integrationId])
  @@index([provider])
  @@index([status])
}
